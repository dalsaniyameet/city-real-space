{
  "version": 2,
  "builds": [
    { "src": "backend/server.js", "use": "@vercel/node" },
    { "src": "*.html",            "use": "@vercel/static" },
    { "src": "*.css",             "use": "@vercel/static" },
    { "src": "*.js",              "use": "@vercel/static" },
    { "src": "images/**",         "use": "@vercel/static" },
    { "src": "admin/**",          "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/server.js" },
    { "src": "/images/(.*)",          "dest": "/images/$1" },
    { "src": "/admin/images/(.*)",    "dest": "/images/$1" },
    { "src": "/admin/(.*\\.html)",    "dest": "/admin/$1" },
    { "src": "/admin/(.*\\.css)",     "dest": "/admin/$1" },
    { "src": "/admin/style.css",       "dest": "/admin/style.css" },
    { "src": "/admin/script.js",       "dest": "/admin/script.js" },
    { "src": "/admin/admin-script.js", "dest": "/admin/admin-script.js" },
    { "src": "/admin/cursor.js",       "dest": "/cursor.js" },
    { "src": "/admin/splash.js",       "dest": "/splash.js" },
    { "src": "/admin/bg-animation.js", "dest": "/bg-animation.js" },
    { "src": "/admin/responsive.css",  "dest": "/responsive.css" },
    { "src": "/admin/script.js",       "dest": "/script.js" },
    { "src": "/admin/(.*\\.js)",       "dest": "/admin/$1" },
    { "src": "/(.*\\.css)",           "dest": "/$1" },
    { "src": "/(.*\\.js)",            "dest": "/$1" },
    { "src": "/(.*\\.html)",          "dest": "/$1" },
    { "src": "/(.*\\.json)",          "dest": "/$1" },
    { "src": "/(.*\\.xml)",           "dest": "/$1" },
    { "src": "/(.*\\.txt)",           "dest": "/$1" },
    { "src": "/(.*\\.(jpg|jpeg|png|gif|svg|ico|webp))", "dest": "/$1" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/login",          "dest": "/login.html" },
    { "src": "/register",       "dest": "/register.html" },
    { "src": "/properties",     "dest": "/properties.html" },
    { "src": "/property-detail","dest": "/property-detail.html" },
    { "src": "/contact",        "dest": "/contact.html" },
    { "src": "/about",          "dest": "/about.html" },
    { "src": "/blog",           "dest": "/blog.html" },
    { "src": "/blog-detail",    "dest": "/blog-detail.html" },
    { "src": "/dashboard",      "dest": "/dashboard.html" },
    { "src": "/buy",            "dest": "/buy.html" },
    { "src": "/rent",           "dest": "/rent.html" },
    { "src": "/resale",         "dest": "/resale.html" },
    { "src": "/land",           "dest": "/land.html" },
    { "src": "/new-launch",     "dest": "/new-launch.html" },
    { "src": "/prelease",       "dest": "/prelease.html" },
    { "src": "/post-property",  "dest": "/post-property.html" },
    { "src": "/careers",        "dest": "/careers.html" },
    { "src": "/faq",            "dest": "/faq.html" },
    { "src": "/privacy",        "dest": "/privacy.html" },
    { "src": "/terms",          "dest": "/terms.html" },
    { "src": "/maintenance",    "dest": "/maintenance.html" },
    { "src": "/(.*)", "dest": "/404.html" }
  ],
  "cleanUrls": false
}
