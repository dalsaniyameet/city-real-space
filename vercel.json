{
  "version": 2,
  "builds": [
    { "src": "backend/server.js", "use": "@vercel/node" },
    { "src": "*.html",            "use": "@vercel/static" },
    { "src": "*.css",             "use": "@vercel/static" },
    { "src": "*.js",              "use": "@vercel/static" },
    { "src": "images/**",         "use": "@vercel/static" },
    { "src": "admin/**",          "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/sitemap.xml",   "dest": "backend/server.js" },
    { "src": "/robots.txt",    "dest": "backend/server.js" },
    { "src": "/google5N74CYScjt-N-OmxhcBkgdSd4ly-4FYBC0S82nxXFBk.html", "dest": "backend/server.js" },
    { "src": "/api/(.*)",      "dest": "backend/server.js" },

    { "src": "/images/(.*)",   "dest": "/images/$1" },

    { "src": "/admin/admin-script.js", "dest": "/admin/admin-script.js" },
    { "src": "/admin/script.js",       "dest": "/admin/script.js" },
    { "src": "/admin/style.css",       "dest": "/admin/style.css" },
    { "src": "/admin/login",           "dest": "/admin/login.html" },
    { "src": "/admin",                 "dest": "/admin/index.html" },
    { "src": "/admin/(.*\\.html)",     "dest": "/admin/$1" },
    { "src": "/admin/(.*\\.css)",      "dest": "/admin/$1" },
    { "src": "/admin/(.*\\.js)",       "dest": "/admin/$1" },
    { "src": "/admin/images/(.*)",     "dest": "/images/$1" },
    { "src": "/admin/cursor.js",       "dest": "/cursor.js" },

    { "src": "/(.*\\.css)",    "dest": "/$1" },
    { "src": "/(.*\\.js)",     "dest": "/$1" },
    { "src": "/(.*\\.html)",   "dest": "/$1" },
    { "src": "/(.*\\.json)",   "dest": "/$1" },
    { "src": "/(.*\\.xml)",    "dest": "/$1" },
    { "src": "/(.*\\.txt)",    "dest": "/$1" },
    { "src": "/(.*\\.(jpg|jpeg|png|gif|svg|ico|webp))", "dest": "/$1" },

    { "src": "/",              "dest": "/index.html" },
    { "src": "/login",         "dest": "/login.html" },
    { "src": "/register",      "dest": "/register.html" },
    { "src": "/properties",    "dest": "/properties.html" },
    { "src": "/property-detail", "dest": "/property-detail.html" },
    { "src": "/property/([^/]+)/([^/]+)/([^/]+)", "dest": "backend/server.js" },
    { "src": "/property/([^/]+)", "dest": "backend/server.js" },
    { "src": "/contact",       "dest": "/contact.html" },
    { "src": "/about",         "dest": "/about.html" },
    { "src": "/blog",          "dest": "/blog.html" },
    { "src": "/blog-detail",   "dest": "/blog-detail.html" },
    { "src": "/dashboard",     "dest": "/dashboard.html" },
    { "src": "/buy",           "dest": "/buy.html" },
    { "src": "/rent",          "dest": "/rent.html" },
    { "src": "/resale",        "dest": "/resale.html" },
    { "src": "/land",          "dest": "/land.html" },
    { "src": "/new-launch",    "dest": "/new-launch.html" },
    { "src": "/prelease",      "dest": "/prelease.html" },
    { "src": "/post-property", "dest": "/post-property.html" },
    { "src": "/careers",       "dest": "/careers.html" },
    { "src": "/faq",           "dest": "/faq.html" },
    { "src": "/privacy",       "dest": "/privacy.html" },
    { "src": "/terms",         "dest": "/terms.html" },
    { "src": "/maintenance",   "dest": "/maintenance.html" },
    { "src": "/(.*)",          "dest": "/404.html" }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/:path*", "has": [{"type": "host", "value": "cityrealspace.com"}], "destination": "https://www.cityrealspace.com/:path*", "permanent": true },
    { "source": "/index.html",           "destination": "/",               "permanent": true },
    { "source": "/properties.html",      "destination": "/properties",     "permanent": true },
    { "source": "/property-detail.html", "destination": "/property-detail","permanent": true },
    { "source": "/about.html",           "destination": "/about",          "permanent": true },
    { "source": "/contact.html",         "destination": "/contact",        "permanent": true },
    { "source": "/blog.html",            "destination": "/blog",           "permanent": true },
    { "source": "/blog-detail.html",     "destination": "/blog-detail",    "permanent": true },
    { "source": "/login.html",           "destination": "/login",          "permanent": true },
    { "source": "/register.html",        "destination": "/register",       "permanent": true },
    { "source": "/dashboard.html",       "destination": "/dashboard",      "permanent": true },
    { "source": "/post-property.html",   "destination": "/post-property",  "permanent": true },
    { "source": "/buy.html",             "destination": "/buy",            "permanent": true },
    { "source": "/rent.html",            "destination": "/rent",           "permanent": true },
    { "source": "/resale.html",          "destination": "/resale",         "permanent": true },
    { "source": "/land.html",            "destination": "/land",           "permanent": true },
    { "source": "/new-launch.html",      "destination": "/new-launch",     "permanent": true },
    { "source": "/prelease.html",        "destination": "/prelease",       "permanent": true },
    { "source": "/faq.html",             "destination": "/faq",            "permanent": true },
    { "source": "/privacy.html",         "destination": "/privacy",        "permanent": true },
    { "source": "/terms.html",           "destination": "/terms",          "permanent": true },
    { "source": "/careers.html",         "destination": "/careers",        "permanent": true }
  ]
}
